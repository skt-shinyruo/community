<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="unknown-service"/>
    <springProperty scope="context" name="serviceVersion" source="community.logging.service-version" defaultValue="unknown"/>
    <springProperty scope="context" name="logDir" source="community.logging.dir" defaultValue="/var/log/community"/>
    <springProperty scope="context" name="logFileName" source="community.logging.file-name" defaultValue="unknown-service.json.log"/>

    <property name="TEXT_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [service.name=${serviceName} service.version=${serviceVersion} trace.id=%X{traceId:-}] %logger - %msg%n%ex"/>

    <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <charset>UTF-8</charset>
            <pattern>${TEXT_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <fieldName>@timestamp</fieldName>
                    <timeZone>UTC</timeZone>
                </timestamp>
                <pattern>
                    <pattern>{"service.name":"${serviceName}","service.version":"${serviceVersion}","trace.id":"%mdc{traceId}"}</pattern>
                </pattern>
                <mdc>
                    <includeMdcKeyName>event.category</includeMdcKeyName>
                    <includeMdcKeyName>event.action</includeMdcKeyName>
                    <includeMdcKeyName>event.outcome</includeMdcKeyName>
                    <includeMdcKeyName>event.truncated</includeMdcKeyName>
                    <includeMdcKeyName>error.type</includeMdcKeyName>
                    <includeMdcKeyName>error.message</includeMdcKeyName>
                    <includeMdcKeyName>duration.ms</includeMdcKeyName>
                    <includeMdcKeyName>threshold.ms</includeMdcKeyName>
                    <includeMdcKeyName>threshold.percent</includeMdcKeyName>
                    <includeMdcKeyName>threshold.count</includeMdcKeyName>
                    <includeMdcKeyName>spring.profiles.active</includeMdcKeyName>
                    <includeMdcKeyName>server.port</includeMdcKeyName>
                    <includeMdcKeyName>cache.system</includeMdcKeyName>
                    <includeMdcKeyName>cache.mode</includeMdcKeyName>
                    <includeMdcKeyName>cache.operation</includeMdcKeyName>
                    <includeMdcKeyName>cache.pool.active</includeMdcKeyName>
                    <includeMdcKeyName>cache.pool.idle</includeMdcKeyName>
                    <includeMdcKeyName>cache.pool.pending</includeMdcKeyName>
                    <includeMdcKeyName>cache.name</includeMdcKeyName>
                    <includeMdcKeyName>cache.hit.count</includeMdcKeyName>
                    <includeMdcKeyName>cache.miss.count</includeMdcKeyName>
                    <includeMdcKeyName>cache.hit.ratio.percent</includeMdcKeyName>
                    <includeMdcKeyName>net.peer.name</includeMdcKeyName>
                    <includeMdcKeyName>messaging.system</includeMdcKeyName>
                    <includeMdcKeyName>messaging.destination.name</includeMdcKeyName>
                    <includeMdcKeyName>messaging.kafka.partition</includeMdcKeyName>
                    <includeMdcKeyName>messaging.kafka.consumer.group</includeMdcKeyName>
                    <includeMdcKeyName>messaging.kafka.consumer.lag</includeMdcKeyName>
                    <includeMdcKeyName>messaging.kafka.rebalance.reason</includeMdcKeyName>
                    <includeMdcKeyName>messaging.kafka.partition.count</includeMdcKeyName>
                    <includeMdcKeyName>db.operation</includeMdcKeyName>
                    <includeMdcKeyName>db.mybatis.statement</includeMdcKeyName>
                    <includeMdcKeyName>db.rows.bucket</includeMdcKeyName>
                    <includeMdcKeyName>oss.operation</includeMdcKeyName>
                    <includeMdcKeyName>oss.bucket</includeMdcKeyName>
                    <includeMdcKeyName>object.size.bucket</includeMdcKeyName>
                    <includeMdcKeyName>error.code</includeMdcKeyName>
                    <includeMdcKeyName>peer.service</includeMdcKeyName>
                    <includeMdcKeyName>jvm.classes.loaded</includeMdcKeyName>
                    <includeMdcKeyName>jvm.classes.unloaded</includeMdcKeyName>
                    <includeMdcKeyName>jvm.classes.loaded.delta</includeMdcKeyName>
                    <includeMdcKeyName>logging.appender.name</includeMdcKeyName>
                    <includeMdcKeyName>logging.queue.name</includeMdcKeyName>
                    <includeMdcKeyName>logging.queue.used</includeMdcKeyName>
                    <includeMdcKeyName>logging.queue.capacity</includeMdcKeyName>
                    <includeMdcKeyName>logging.queue.used.percent</includeMdcKeyName>
                    <includeMdcKeyName>job.system</includeMdcKeyName>
                    <includeMdcKeyName>job.name</includeMdcKeyName>
                    <includeMdcKeyName>job.skip.reason</includeMdcKeyName>
                    <includeMdcKeyName>security.control</includeMdcKeyName>
                    <includeMdcKeyName>security.subject.type</includeMdcKeyName>
                    <includeMdcKeyName>rate.limit.current</includeMdcKeyName>
                    <includeMdcKeyName>rate.limit.threshold</includeMdcKeyName>
                    <includeMdcKeyName>process.fd.used</includeMdcKeyName>
                    <includeMdcKeyName>process.fd.max</includeMdcKeyName>
                    <includeMdcKeyName>process.fd.used.percent</includeMdcKeyName>
                    <includeMdcKeyName>filesystem.mount</includeMdcKeyName>
                    <includeMdcKeyName>disk.used.bytes</includeMdcKeyName>
                    <includeMdcKeyName>disk.total.bytes</includeMdcKeyName>
                    <includeMdcKeyName>disk.used.percent</includeMdcKeyName>
                    <includeMdcKeyName>process.cpu.load.percent</includeMdcKeyName>
                    <includeMdcKeyName>instrumentation.action</includeMdcKeyName>
                    <includeMdcKeyName>jvm.version</includeMdcKeyName>
                    <includeMdcKeyName>jvm.vendor</includeMdcKeyName>
                    <includeMdcKeyName>jvm.available.processors</includeMdcKeyName>
                    <includeMdcKeyName>jvm.heap.max.bytes</includeMdcKeyName>
                    <includeMdcKeyName>jvm.memory.area</includeMdcKeyName>
                    <includeMdcKeyName>jvm.memory.used.bytes</includeMdcKeyName>
                    <includeMdcKeyName>jvm.memory.max.bytes</includeMdcKeyName>
                    <includeMdcKeyName>jvm.memory.used.percent</includeMdcKeyName>
                    <includeMdcKeyName>jvm.gc.name</includeMdcKeyName>
                    <includeMdcKeyName>jvm.gc.pause.ms</includeMdcKeyName>
                    <includeMdcKeyName>process.timezone</includeMdcKeyName>
                    <includeMdcKeyName>process.charset</includeMdcKeyName>
                    <includeMdcKeyName>executor.name</includeMdcKeyName>
                    <includeMdcKeyName>executor.active</includeMdcKeyName>
                    <includeMdcKeyName>executor.pool.size</includeMdcKeyName>
                    <includeMdcKeyName>executor.queue.size</includeMdcKeyName>
                    <includeMdcKeyName>executor.queue.remaining</includeMdcKeyName>
                    <includeMdcKeyName>executor.rejected.count</includeMdcKeyName>
                    <includeMdcKeyName>executor.active.percent</includeMdcKeyName>
                    <includeMdcKeyName>db.system</includeMdcKeyName>
                    <includeMdcKeyName>db.pool.name</includeMdcKeyName>
                    <includeMdcKeyName>db.pool.active</includeMdcKeyName>
                    <includeMdcKeyName>db.pool.idle</includeMdcKeyName>
                    <includeMdcKeyName>db.pool.total</includeMdcKeyName>
                    <includeMdcKeyName>db.pool.pending</includeMdcKeyName>
                    <includeMdcKeyName>http.request.method</includeMdcKeyName>
                    <includeMdcKeyName>url.path</includeMdcKeyName>
                    <includeMdcKeyName>http.response.status_code</includeMdcKeyName>
                </mdc>
                <logLevel>
                    <fieldName>level</fieldName>
                </logLevel>
                <loggerName>
                    <fieldName>logger</fieldName>
                </loggerName>
                <message/>
                <stackTrace>
                    <fieldName>stack_trace</fieldName>
                </stackTrace>
            </providers>
        </encoder>
