<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nowcoder.community.growth.mapper.AdminRewardOrderActionMapper">

    <insert id="insert" parameterType="com.nowcoder.community.growth.entity.AdminRewardOrderAction" useGeneratedKeys="true" keyProperty="id">
        insert into admin_reward_order_action(
            order_id,
            actor_user_id,
            action,
            from_status,
            to_status,
            note
        ) values (
            #{orderId},
            #{actorUserId},
            #{action},
            #{fromStatus},
            #{toStatus},
            #{note}
        )
    </insert>

</mapper>
