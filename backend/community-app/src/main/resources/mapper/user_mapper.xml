<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nowcoder.community.user.mapper.UserMapper">

    <sql id="insertFields">
        username, password, salt, email, type, status, activation_code, header_url, create_time
    </sql>

    <sql id="selectFields">
        id, username, password, salt, email, type, status, activation_code, header_url, create_time, score, mute_until, ban_until
    </sql>

    <select id="selectById" resultType="com.nowcoder.community.user.entity.User">
        select
        <include refid="selectFields"></include>
        from user
        where id = #{id}
    </select>

    <select id="selectByName" resultType="com.nowcoder.community.user.entity.User">
        select
        <include refid="selectFields"></include>
        from user
        where username = #{username}
    </select>

    <select id="selectByEmail" resultType="com.nowcoder.community.user.entity.User">
        select
        <include refid="selectFields"></include>
        from user
        where email = #{email}
    </select>

    <insert id="insertUser" parameterType="com.nowcoder.community.user.entity.User" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        insert into user (<include refid="insertFields"></include>)
        values(#{username}, #{password}, #{salt}, #{email}, #{type}, #{status}, #{activationCode}, #{headerUrl},
        #{createTime})
    </insert>

    <update id="updateStatus">
        update user set status = #{status} where id = #{id}
    </update>

    <update id="updateHeader">
        update user set header_url = #{headerUrl} where id = #{id}
    </update>

    <update id="updatePassword">
        update user set password = #{password} where id = #{id}
    </update>

    <update id="updateType">
        update user set type = #{type} where id = #{id}
    </update>

    <update id="updateModerationUntil">
        update user
        set mute_until = #{muteUntil},
            ban_until = #{banUntil}
        where id = #{id}
    </update>

    <update id="addScore">
        update user
        set score = case
            when score + #{delta} &lt; 0 then 0
            else score + #{delta}
        end
        where id = #{id}
    </update>

    <select id="selectTopByScore" resultType="com.nowcoder.community.user.entity.User">
        select
        <include refid="selectFields"></include>
        from user
        order by score desc, id asc
        limit #{limit}
    </select>

    <select id="selectModerationUsersAfterId" resultType="com.nowcoder.community.user.entity.User">
        select id, mute_until, ban_until
        from user
        where id &gt; #{afterId}
        order by id asc
        limit #{limit}
    </select>

    <select id="selectUserSummariesByIds" resultType="com.nowcoder.community.user.entity.User">
        select id, username, header_url, type
        from user
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>
