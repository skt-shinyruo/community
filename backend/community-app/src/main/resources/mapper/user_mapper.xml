<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nowcoder.community.user.infrastructure.persistence.mapper.UserMapper">

    <sql id="insertFields">
        id, username, password, salt, email, type, status, header_url, create_time
    </sql>

    <sql id="selectFields">
        id, username, password, salt, email, type, status, header_url, create_time, mute_until, ban_until
    </sql>

    <select id="selectById" resultType="com.nowcoder.community.user.infrastructure.persistence.dataobject.UserDataObject">
        select
        <include refid="selectFields"></include>
        from user
        where id = #{id, jdbcType=BINARY}
    </select>

    <select id="selectByName" resultType="com.nowcoder.community.user.infrastructure.persistence.dataobject.UserDataObject">
        select
        <include refid="selectFields"></include>
        from user
        where username = #{username}
    </select>

    <select id="selectByEmail" resultType="com.nowcoder.community.user.infrastructure.persistence.dataobject.UserDataObject">
        select
        <include refid="selectFields"></include>
        from user
        where email = #{email}
    </select>

    <insert id="insertUser" parameterType="com.nowcoder.community.user.infrastructure.persistence.dataobject.UserDataObject">
        insert into user (<include refid="insertFields"></include>)
        values(#{id, jdbcType=BINARY}, #{username}, #{password}, #{salt}, #{email}, #{type}, #{status}, #{headerUrl},
        #{createTime})
    </insert>

    <update id="updateStatus">
        update user set status = #{status} where id = #{id, jdbcType=BINARY}
    </update>

    <update id="updateHeader">
        update user set header_url = #{headerUrl} where id = #{id, jdbcType=BINARY}
    </update>

    <update id="updatePassword">
        update user set password = #{password} where id = #{id, jdbcType=BINARY}
    </update>

    <update id="updateType">
        update user set type = #{type} where id = #{id, jdbcType=BINARY}
    </update>

    <update id="updateModerationUntil">
        update user
        set mute_until = #{muteUntil},
            ban_until = #{banUntil}
        where id = #{id, jdbcType=BINARY}
    </update>

    <select id="selectModerationUsersAfterId" resultType="com.nowcoder.community.user.infrastructure.persistence.dataobject.UserDataObject">
        select id, mute_until, ban_until
        from user
        where id &gt; #{afterId, jdbcType=BINARY}
        order by id asc
        limit #{limit}
    </select>

    <select id="selectUserSummariesByIds" resultType="com.nowcoder.community.user.infrastructure.persistence.dataobject.UserDataObject">
        select id, username, header_url, type
        from user
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id, jdbcType=BINARY}
        </foreach>
    </select>

</mapper>
