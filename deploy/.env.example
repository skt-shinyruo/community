### Local docker-compose defaults (copy to .env)

# Spring profiles
# - 本地开发：dev（默认）
# - 生产部署：prod（启用 required Nacos import + StartupValidation fail-closed）
SPRING_PROFILES_ACTIVE=dev

# Trusted proxy / Real IP（反代/Ingress 场景可选）
# - 默认 fail-closed：不信任 X-Forwarded-For（避免伪造风险）
# - 生产环境如启用，请务必配置“可信代理 CIDR allowlist”（只能信任反代层 IP 段）
GATEWAY_TRUSTED_PROXY_ENABLED=false
# 示例（生产在 Nginx/Ingress 后）：
# GATEWAY_TRUSTED_PROXY_ENABLED=true
# GATEWAY_TRUSTED_PROXY_CIDRS=10.0.0.0/8,192.168.0.0/16,127.0.0.1/32,::1/128
# 注意：禁止使用 0.0.0.0/0 或 ::/0（全量信任会导致 XFF 伪造，prod 下 StartupValidation 会阻断启动）

# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=community
MYSQL_USER=community
MYSQL_PASSWORD=communitypass
MYSQL_DATABASES=community,community_content,community_message,community_search,community_social

# MySQL (P0) - per-service schemas/users (same instance, different schema)
CONTENT_DB_NAME=community_content
CONTENT_DB_USER=community_content
CONTENT_DB_PASSWORD=community_contentpass

MESSAGE_DB_NAME=community_message
MESSAGE_DB_USER=community_message
MESSAGE_DB_PASSWORD=community_messagepass

SEARCH_DB_NAME=community_search
SEARCH_DB_USER=community_search
SEARCH_DB_PASSWORD=community_searchpass

SOCIAL_DB_NAME=community_social
SOCIAL_DB_USER=community_social
SOCIAL_DB_PASSWORD=community_socialpass

# user-service DB credentials (avoid reusing MYSQL_USER/MYSQL_PASSWORD in service configs)
USER_DB_USERNAME=community
USER_DB_PASSWORD=communitypass

# JWT (must be >= 32 bytes) - all services share this secret in local compose
JWT_HMAC_SECRET=dev-secret-please-change-at-least-32bytes

# Auth refresh cookie (local http dev)
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=Lax

# Auth onboarding (dev)
# - 本地默认无 SMTP：通过回传 activationLink/resetLink 形成闭环
# - 生产环境建议：关闭 expose-* 并启用 SMTP（StartupValidation 会在 prod 下强制校验）
AUTH_ACTIVATION_BASE_URL=http://localhost:12881
AUTH_MAIL_ENABLED=false
AUTH_EXPOSE_ACTIVATION_LINK=true
AUTH_EXPOSE_RESET_LINK=true

# Actuator / Prometheus basic auth (local dev)
METRICS_BASIC_AUTH_USERNAME=prometheus
METRICS_BASIC_AUTH_PASSWORD=dev-prometheus-pass

# Internal tokens (dev only) - per-service isolation (no global fallback)
USER_INTERNAL_TOKEN=dev-user-internal-token
USER_INTERNAL_TOKEN_PREVIOUS=
USER_OPS_INTERNAL_TOKEN=dev-user-ops-internal-token
USER_OPS_INTERNAL_TOKEN_PREVIOUS=
CONTENT_INTERNAL_TOKEN=dev-content-internal-token
CONTENT_INTERNAL_TOKEN_PREVIOUS=
SOCIAL_INTERNAL_TOKEN=dev-social-internal-token
SOCIAL_INTERNAL_TOKEN_PREVIOUS=
ANALYTICS_INTERNAL_TOKEN=dev-analytics-internal-token
SEARCH_INTERNAL_TOKEN=dev-search-internal-token
SEARCH_INTERNAL_TOKEN_PREVIOUS=

# Internal OPS guard (break-glass) - X-Ops-Token (leave empty by default)
OPS_CONTENT_TOKEN=
OPS_CONTENT_TOKEN_PREVIOUS=
OPS_SOCIAL_TOKEN=
OPS_SOCIAL_TOKEN_PREVIOUS=
OPS_USERS_TOKEN=
OPS_USERS_TOKEN_PREVIOUS=
OPS_SEARCH_TOKEN=
OPS_SEARCH_TOKEN_PREVIOUS=

OPS_OUTBOX_REPLAY_ENABLED=false
OPS_OUTBOX_REPLAY_ALLOWLIST=127.0.0.1,::1
OPS_SEARCH_REINDEX_ENABLED=false
OPS_SEARCH_REINDEX_ALLOWLIST=127.0.0.1,::1
OPS_RATE_WINDOW_SECONDS=60
OPS_RATE_MAX=3
OPS_LOCK_TTL_SECONDS=600

# Redis hosts (optional overrides)
USER_REDIS_HOST=redis
USER_REDIS_PORT=6379
MESSAGE_REDIS_HOST=redis
MESSAGE_REDIS_PORT=6379
SEARCH_REDIS_HOST=redis
SEARCH_REDIS_PORT=6379

# user-service avatar/files (dev default: local filesystem)
USER_AVATAR_STORAGE=local
USER_FILES_BASE_DIR=/data/files
USER_PUBLIC_BASE_URL=http://localhost:12881
