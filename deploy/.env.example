### Local docker-compose defaults (copy to .env)

# MySQL
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=community
MYSQL_USER=community
MYSQL_PASSWORD=communitypass

# JWT (must be >= 32 bytes)
JWT_HMAC_SECRET=dev-secret-please-change-at-least-32bytes

# Internal tokens (dev only)
ANALYTICS_INTERNAL_TOKEN=dev-analytics-internal-token
SEARCH_INTERNAL_TOKEN=dev-search-internal-token
