# 复制为 deploy/.env 后再启动：docker compose --env-file deploy/.env -f deploy/docker-compose.yml up -d

NACOS_SERVER_ADDR=127.0.0.1:8848

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=community
MYSQL_USER=community
MYSQL_PASSWORD=community

# 仅用于本地开发示例：JWT HMAC 密钥建议 >= 32 字节，生产环境务必替换并妥善保管
GATEWAY_JWT_HMAC_SECRET=dev-change-me-please-at-least-32-bytes
AUTH_JWT_HMAC_SECRET=dev-change-me-please-at-least-32-bytes

