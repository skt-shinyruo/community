### Local single-node topology defaults (copy to .env.single)

# 说明：
# - 本文件为 `deploy/.env.single` 的环境变量示例；请复制后再按需修改。
# - 推荐 operator 入口：
#   - `./deploy/deployment.sh up --topology single`
#   - `./deploy/deployment.sh up --topology single --scope infra`
#   - `./deploy/deployment.sh up --topology single --observability`
# - 对应显式 layered compose 主路径：
#   `docker compose --env-file deploy/.env.single -p community-single -f deploy/compose.yml -f deploy/compose.infra.*.single.yml -f deploy/compose.infra.mailhog.yml ...`
# - 这些变量会同时用于：
#   1) docker compose 变量替换（如 MySQL 初始化参数）
#   2) 注入到后端容器，成为 Spring Boot 可读取的环境变量（映射到 application.yml 的配置项）
# - 生产环境请不要使用示例口令/密钥；建议通过 Secret/KMS/配置中心注入，并启用 `SPRING_PROFILES_ACTIVE=prod`。

# Optional overlays on top of the base stack
# - observability（Elastic / Kibana）：`./deploy/deployment.sh up --topology single --observability` / 追加 `-f deploy/compose.observability.yml`

# Local single-node ingress defaults
# - NGINX_API_PORT：本地统一业务入口端口（API / files / IM）
# - FRONTEND_HOST_PORT：前端页面入口端口
# - NGINX_XXL_JOB_PORT：本地 XXL-JOB Admin 入口端口
# - 下列 REPLICA_COUNT 仅作为文档上的单体默认值表达；当前 compose 仍采用显式 service 命名
NGINX_API_PORT=12880
FRONTEND_HOST_PORT=12881
NGINX_XXL_JOB_PORT=12887
GATEWAY_REPLICA_COUNT=1
APP_REPLICA_COUNT=1
IM_CORE_REPLICA_COUNT=1
IM_REALTIME_REPLICA_COUNT=1
BROWSER_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:12881,http://127.0.0.1:12881,http://localhost:12888,http://127.0.0.1:12888
FRONTEND_PUBLIC_ORIGIN=http://localhost:12881
GATEWAY_PUBLIC_BASE_URL=http://localhost:12880
IM_WS_PUBLIC_URL=ws://localhost:12880/ws/im
NACOS_SERVER_ADDR=nacos:8848
NACOS_HOST_PORT=18848
NACOS_MYSQL_HOST=mysql
NACOS_MYSQL_PORT=3306
NACOS_MYSQL_DATABASE=nacos
NACOS_MYSQL_USER=nacos
NACOS_MYSQL_PASSWORD=nacospass
NACOS_MYSQL_DB_PARAM=characterEncoding=utf8&connectTimeout=1000&socketTimeout=3000&autoReconnect=true&useSSL=false&allowPublicKeyRetrieval=true
IM_CORE_SERVICE_ID=im-core
IM_COMMUNITY_SERVICE_ID=community-app
IM_REALTIME_WORKER_SERVICE_ID=im-realtime-worker
IM_REALTIME_WORKER_ID_PREFIX=im-realtime
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
# Kafka KRaft metadata quorum
# - `KAFKA_BOOTSTRAP_SERVERS` keeps the app-facing broker list unchanged
# - `KAFKA_KRAFT_CLUSTER_ID` 仍用于单节点 KRaft 初始化
# - if you change `KAFKA_KRAFT_CLUSTER_ID`, delete existing `kafka_*` volumes first
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_KRAFT_CLUSTER_ID=lPHxXLw5RVixWxVWRmsjHA
ELASTICSEARCH_URIS=http://elasticsearch:9200
DB_PRIMARY_HOST=mysql
IM_CORE_DB_PRIMARY_HOST=mysql
XXL_JOB_ADMIN_INGRESS_URL=http://nginx:8081/xxl-job-admin

# Dev-only helper services
# - mock-data-studio: localhost-only control-plane shell for demo / mock-data workflows
# - `MOCK_DATA_STUDIO_ENABLED`: whether to keep the studio service alive at all
# - `MOCK_DATA_STUDIO_PORT`: process/listen port inside the service
# - `MOCK_DATA_STUDIO_HOST_PORT`: localhost port exposed by compose on the host
# - 默认 host port 使用 `12890`，避免与 Elastic localhost 入口 `12888` 冲突
# - `MOCK_DATA_STUDIO_DB_USER` / `MOCK_DATA_STUDIO_DB_PASSWORD`: dedicated studio MySQL user
#   with schema-wide `select/insert/update/delete/create` on `community`
#   so startup bootstrap works and later studio flows can write business tables directly
MOCK_DATA_STUDIO_ENABLED=true
MOCK_DATA_STUDIO_HOST_PORT=12890
MOCK_DATA_STUDIO_PORT=12888
MOCK_DATA_STUDIO_DB_USER=mock_data_studio
MOCK_DATA_STUDIO_DB_PASSWORD=mockdatastudiopass
MOCK_DATA_AUTO_FILL_ENABLED=false
MOCK_DATA_AUTO_FILL_SCENE=tech-community-hot-start
MOCK_DATA_DEFAULT_USERS=100
MOCK_DATA_DEFAULT_POSTS=800
MOCK_DATA_DEFAULT_COMMENTS=2500
# Optional AI enhancement for manual-generate jobs only
MOCK_DATA_STUDIO_AI_ENABLED=false
MOCK_DATA_STUDIO_OPENAI_API_KEY=
MOCK_DATA_STUDIO_OPENAI_MODEL=gpt-4.1-mini
MOCK_DATA_STUDIO_OPENAI_TIMEOUT_MS=8000
MOCK_DATA_STUDIO_AI_MAX_ITEMS_PER_JOB=20
# Optional authenticated ops reindex for mock-data-studio; defaults to JWT_HMAC_SECRET if omitted
MOCK_DATA_STUDIO_REINDEX_JWT_HMAC_SECRET=
MOCK_DATA_STUDIO_REINDEX_JWT_ISSUER=community-auth
MOCK_DATA_STUDIO_REINDEX_JWT_TTL_SECONDS=120

# Spring profiles
# - 本地开发：dev（默认）
# - 生产部署：prod（建议：启用更严格的启动校验与安全策略）
# - 注意：prod profile 下会启用“启动期校验（fail-closed）”，关键密钥缺失会直接阻断启动
SPRING_PROFILES_ACTIVE=dev

# MySQL
# - 以下变量用于初始化 MySQL 容器（同时也会被后端用于拼接 JDBC 连接信息）
# - 生产环境请替换为强口令，并避免将真实口令提交到仓库
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=community
MYSQL_USER=community
MYSQL_PASSWORD=communitypass

# JWT (must be >= 32 bytes) - all services share this secret in local compose
# - 用途：JWT HS256 的签名/验签密钥（后端 security.jwt.hmac-secret）
# - 约束：长度建议 >= 32 字节（不足会导致服务启动失败或请求验签失败）
# - 本地 compose 下多个后端服务（community-app / im-core / im-realtime）共享同一密钥，必须保持一致
# - 当前示例值可直接启动本地 compose，但仍应在你自己的 deploy/.env 中替换为专用随机值
JWT_HMAC_SECRET=dev-local-jwt-hmac-secret-change-before-sharing-20260320

# Auth refresh cookie (local http dev)
# - 用途：refresh token cookie 的安全属性（security.jwt.refresh-cookie-*)
# - AUTH_REFRESH_COOKIE_SECURE：
#   - 本地 http 可设为 false；生产 https 建议 true（否则浏览器可能拒绝/降级 cookie）
# - AUTH_REFRESH_COOKIE_SAME_SITE：允许值 Lax / Strict / None（跨站点 cookie 通常需要 None + Secure=true）
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=Lax

# Auth onboarding (dev)
# - 本地默认启用 MailHog：通过 SMTP 邮件完成注册验证码/找回密码闭环（UI: http://localhost:8025）
# - 可选 dev-only 快捷模式：关闭 SMTP 并开启 expose-*（不推荐用于非纯本机环境）
# - 生产环境建议：关闭 expose-* 并启用真实 SMTP（StartupValidation 会在 prod 下强制校验）
# - AUTH_REGISTRATION_PENDING_USER_TTL_SECONDS：未激活注册账号存活时间（秒），超过后允许重新注册
# - AUTH_REGISTRATION_PENDING_USER_CLEANUP_INTERVAL_MS：后台清理过期未激活账号的 fixed-delay（毫秒）
# - AUTH_MAIL_ENABLED：是否启用 SMTP 发信（auth.registration.mail.enabled）
# - 本地 compose 下，找回密码邮件中重置链接统一使用 FRONTEND_PUBLIC_ORIGIN
# - AUTH_REGISTRATION_EXPOSE_CODE / AUTH_EXPOSE_RESET_LINK：是否在接口响应中直接回传调试验证码/重置链接（仅建议纯本机调试临时开启；生产建议关闭）
AUTH_REGISTRATION_PENDING_USER_TTL_SECONDS=1800
AUTH_REGISTRATION_PENDING_USER_CLEANUP_INTERVAL_MS=300000
AUTH_REGISTRATION_PENDING_USER_LOCAL_SCHEDULER_ENABLED=false
AUTH_MAIL_ENABLED=true
AUTH_REGISTRATION_EXPOSE_CODE=false
AUTH_EXPOSE_RESET_LINK=false

# XXL-JOB (local compose)
# - 用途：本地分布式任务控制面与 executor 注册
# - admin UI：默认仅绑定到 `127.0.0.1:${XXL_JOB_ADMIN_PORT}`
# - `XXL_JOB_ACCESS_TOKEN`：admin/executor 共享 access token，不能为空
# - `XXL_JOB_EXECUTOR_ADDRESS`：必须包含显式端口；当前 community-app 运行时会从该地址解析 bind port
# - `AUTH_REGISTRATION_PENDING_USER_LOCAL_SCHEDULER_ENABLED=false`：启用 XXL 后关闭本地 cleanup `@Scheduled`，避免双跑
# - `XXL_JOB_ADMIN_PASSWORD`：必须 <= 20 个字符；XXL-JOB 登录页前端字段自带 `maxlength=20`
XXL_JOB_ADMIN_PORT=12887
XXL_JOB_MYSQL_USER=xxl_job
XXL_JOB_MYSQL_PASSWORD=xxljobpass
XXL_JOB_ADMIN_USERNAME=admin
XXL_JOB_ADMIN_PASSWORD=dev-local-xxl-admin
XXL_JOB_ACCESS_TOKEN=dev-local-xxl-access-token-change-me
XXL_JOB_ENABLED=true
XXL_JOB_ADMIN_ADDRESSES=http://nginx:8081/xxl-job-admin
XXL_JOB_EXECUTOR_APPNAME=community-app
XXL_JOB_EXECUTOR_TITLE=CommunityApp
XXL_JOB_EXECUTOR_ADDRESS=http://community-app:9999/
XXL_JOB_AUTHOR=community
XXL_JOB_ALARM_EMAIL=
XXL_JOB_PENDING_REGISTRATION_CLEANUP_CRON=0 0/5 * * * ?

# Actuator / Prometheus basic auth (local dev)
# - 用途：保护 `GET /actuator/prometheus` 的 basic-auth（community.metrics.basic-auth.*）
# - 当前本地 compose 不再自带 Prometheus overlay；这里仍保留鉴权配置，便于后续内网抓取或手工验证
# - 生产环境请替换为强口令并通过 Secret 注入（避免被“已知默认值”探测命中）
METRICS_BASIC_AUTH_USERNAME=prometheus
METRICS_BASIC_AUTH_PASSWORD=dev-prometheus-pass

# Elastic / OpenTelemetry (local compose phase 1)
# - `./deploy/deployment.sh up --topology single --observability` 会在基础三层上追加 observability overlay
# - 默认 localhost 入口：Elasticsearch `127.0.0.1:${ELASTICSEARCH_PORT}`，Kibana `127.0.0.1:${KIBANA_PORT}`
# - Phase 1 日志路径固定为：backend structured JSON file appender -> shared observability_logs volume -> EDOT collector filelog -> Elastic
# - `OTEL_EXPORTER_OTLP_ENDPOINT` 为 compose 网络内地址；后续 backend runtime 会使用它把 traces / metrics 发送给 collector
# - `OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf` 与 `:4318` HTTP receiver 对齐
# - `OTEL_JAVA_AGENT_VERSION` 是 backend image 构建时下载 Java agent 的版本钉住点
# - `SERVICE_VERSION` 会同时作为应用运行时元数据和 OTel `service.version` 资源属性来源
# - 若通过 compose override / runtime env 传入 `JAVA_OPTS`，只支持标准“空格分隔 JVM 参数”形式；
#   `backend/scripts/run-backend-service.sh` 不解析 shell quoting
# - `OTEL_ENABLED` 默认保持关闭；只有在启用 Elastic overlay 且需要应用 traces / metrics 时再显式打开
ELASTICSEARCH_PORT=12888
KIBANA_PORT=12889
OTEL_EXPORTER_OTLP_ENDPOINT=http://observability-gateway-edot-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_ENABLED=false
OTEL_JAVA_AGENT_VERSION=2.23.0
SERVICE_VERSION=local-compose

# JVM container memory defaults (local compose)
# - 这套本地 HA 栈里包含大量 JVM 进程；这里给每类 JVM 容器一个可覆盖的默认上限，避免主机内存被“无限堆”抢满。
# - 自研 Spring Boot 服务继续使用 `JAVA_OPTS`，因为 `backend/scripts/run-backend-service.sh` 会直接拼接并传给 `java`。
# - `xxl-job-admin` 改用 `JAVA_TOOL_OPTIONS`，避免依赖镜像里有歧义的 `JAVA_OPTS` 启动写法。
# - `nacos` / `kafka` / `elasticsearch` 分别走各自镜像原生支持的 JVM 变量，减少升级兼容风险。
# - 若机器内存较紧，优先下调 `*_MEM_LIMIT`；若服务启动或压测时 OOM，再成对调整对应的 heap / percentage 参数。
COMMUNITY_APP_MEM_LIMIT=768m
COMMUNITY_APP_JAVA_OPTS=-XX:+UseG1GC -XX:+UseStringDeduplication -XX:InitialRAMPercentage=20.0 -XX:MaxRAMPercentage=60.0 -XX:MaxMetaspaceSize=256m -XX:+ExitOnOutOfMemoryError
COMMUNITY_GATEWAY_MEM_LIMIT=512m
COMMUNITY_GATEWAY_JAVA_OPTS=-XX:+UseG1GC -XX:+UseStringDeduplication -XX:InitialRAMPercentage=20.0 -XX:MaxRAMPercentage=55.0 -XX:MaxMetaspaceSize=192m -XX:+ExitOnOutOfMemoryError
IM_CORE_MEM_LIMIT=640m
IM_CORE_JAVA_OPTS=-XX:+UseG1GC -XX:+UseStringDeduplication -XX:InitialRAMPercentage=20.0 -XX:MaxRAMPercentage=60.0 -XX:MaxMetaspaceSize=192m -XX:+ExitOnOutOfMemoryError
IM_REALTIME_MEM_LIMIT=640m
IM_REALTIME_JAVA_OPTS=-XX:+UseG1GC -XX:+UseStringDeduplication -XX:InitialRAMPercentage=20.0 -XX:MaxRAMPercentage=55.0 -XX:MaxMetaspaceSize=192m -XX:+ExitOnOutOfMemoryError
XXL_JOB_ADMIN_MEM_LIMIT=384m
XXL_JOB_ADMIN_JAVA_TOOL_OPTIONS=-XX:+UseG1GC -XX:InitialRAMPercentage=20.0 -XX:MaxRAMPercentage=60.0 -XX:MaxMetaspaceSize=192m -XX:+ExitOnOutOfMemoryError
NACOS_MEM_LIMIT=768m
NACOS_JVM_XMS=512m
NACOS_JVM_XMX=512m
NACOS_JVM_XMN=256m
NACOS_JVM_MS=128m
NACOS_JVM_MMS=256m
KAFKA_MEM_LIMIT=1g
KAFKA_HEAP_OPTS=-Xms512M -Xmx512M
ELASTICSEARCH_MEM_LIMIT=1g
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# user-service avatar/files (dev default: local filesystem)
# - 用途：用户头像/文件存储策略（user.avatar.*）
# - 访问方式：无论 local 还是 r2，头像/文件都统一通过后端 `/files/**` 读取（最终形如 ${USER_PUBLIC_BASE_URL}/files/<key>）
# - USER_AVATAR_STORAGE：local / r2
#   - local：文件落盘到 USER_FILES_BASE_DIR（需持久化 volume），并由后端 `/files/**` 提供读取（适合自托管/本地）
#   - r2：后端代传到 Cloudflare R2（S3 兼容 API），需要额外配置 R2_* 环境变量；读取仍走后端 `/files/**`
# - USER_FILES_BASE_DIR：仅 local 模式生效；容器内落盘目录；建议映射为持久化 volume（compose 已默认挂载到 /data/files）
# - local 模式下，生成头像对外访问 URL 的 base 统一使用 FRONTEND_PUBLIC_ORIGIN
USER_AVATAR_STORAGE=local
USER_FILES_BASE_DIR=/data/files

# Cloudflare R2 (only when USER_AVATAR_STORAGE=r2)
# - R2_ENDPOINT：S3 兼容接口 endpoint（示例：https://<accountid>.r2.cloudflarestorage.com）
# - R2_ACCESS_KEY / R2_SECRET_KEY：R2 的 Access Key ID / Secret Access Key
# - R2_BUCKET_NAME：桶名
# - R2_REGION：R2 通常使用 auto
# - R2_PATH_STYLE：多数 S3 兼容 endpoint 需要 path-style（默认 true）
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_REGION=auto
R2_PATH_STYLE=true
