FROM node:20-alpine AS frontend-build

WORKDIR /workspace/frontend

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend ./
RUN npm run build

FROM node:20-alpine

WORKDIR /app/frontend

# 复制构建产物与依赖（vite preview 需要 vite 运行时）
COPY --from=frontend-build /workspace/frontend /app/frontend

EXPOSE 12881

CMD ["sh", "-lc", "node scripts/renderRuntimeConfig.mjs && npm run preview -- --host 0.0.0.0 --port 12881 --strictPort"]
