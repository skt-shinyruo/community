FROM maven:3.9.8-eclipse-temurin-17 AS build

WORKDIR /workspace
COPY . .

RUN --mount=type=cache,target=/root/.m2/repository,sharing=locked \
    mvn -q -DskipTests -pl :community-im-db-migrations -am package && \
    cp community-im-db-migrations/target/community-im-db-migrations-*.jar /workspace/community-im-db-migrations.jar

FROM eclipse-temurin:17-jre-jammy

WORKDIR /app
COPY --from=build /workspace/community-im-db-migrations.jar /app/community-im-db-migrations.jar

ENTRYPOINT ["java", "-jar", "/app/community-im-db-migrations.jar"]
CMD ["migrate"]
